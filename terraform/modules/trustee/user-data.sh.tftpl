#!/bin/bash
# Trustee instance initialization script with secret management
set -e

echo "=== Installing Trustee ==="

# Create secrets directory
mkdir -p /opt/trustee/secrets

# Install trustee (following official documentation)
yum install -y trustee jq openssl

# Create KBS repository directory (as per documentation)
mkdir -p /opt/trustee/kbs/repository/default/local-resources/

# Receive secrets from Terraform and store in proper KBS location
echo "${disk_passphrase_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/disk_passphrase
echo "${sshd_server_key_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/sshd_server_key
echo "${sshd_server_pub_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/sshd_server_key.pub
echo "${openclaw_config_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/openclaw_config

# Secret files stored in KBS repository (permissions managed by Trustee)

# Generate certificates for Attestation Service
mkdir -p /tmp/certs

# Generate CA key and certificate
openssl ecparam -genkey -name prime256v1 -out /tmp/certs/as-ca.key
openssl req -x509 -sha256 -nodes -days 365 \
    -key /tmp/certs/as-ca.key \
    -out /tmp/certs/as-ca.pem \
    -subj "/O=Trustee CA" \
    -addext "keyUsage=critical,cRLSign,keyCertSign,digitalSignature"

# Generate AS key and certificate
openssl ecparam -genkey -name prime256v1 -out /tmp/certs/as.key
openssl req -new -key /tmp/certs/as.key -out /tmp/certs/as.csr -subj "/CN=Trustee/O=Trustee CA"
openssl x509 -req -in /tmp/certs/as.csr \
    -CA /tmp/certs/as-ca.pem \
    -CAkey /tmp/certs/as-ca.key \
    -CAcreateserial \
    -out /tmp/certs/as.pem \
    -days 365 \
    -extensions v3_req \
    -extfile <(echo -e "[v3_req]\nsubjectKeyIdentifier = hash") \
    -sha256

# Create full certificate chain
cat /tmp/certs/as.pem /tmp/certs/as-ca.pem > /tmp/certs/as-full.pem


if [ -n "$DEV_TRUSTEE" ]; then 
    # Create default policy for testing
    # WARNING: This policy skips attestation checks - NOT FOR PRODUCTION
    mkdir -p /opt/trustee/attestation-service/policies/opa
    cat > /opt/trustee/attestation-service/policies/opa/default.rego << 'POLICIES_EOF'
package policy

default executables := 3
default hardware := 2
default configuration := 2
default file_system := 2
POLICIES_EOF

else
    # Create default policy
    mkdir -p /opt/trustee/attestation-service/policies/opa
    cat > /opt/trustee/attestation-service/policies/opa/default.rego << 'POLICIES_EOF'
package policy

import rego.v1

# This policy validates multiple TEE platforms
# The policy is meant to capture the TCB requirements
# for confidential instance.

# This policy is used to generate an EAR Appraisal.
# Specifically it generates an AR4SI result.
# More informatino on AR4SI can be found at
# <https://datatracker.ietf.org/doc/draft-ietf-rats-ar4si/>

# For the 'executables' trust claim, the value 33 stands for
# "Runtime memory includes executables, scripts, files, and/or
#  objects which are not recognized."
default executables := 33

# For the 'hardware' trust claim, the value 97 stands for
# "A Verifier does not recognize an Attester's hardware or
#  firmware, but it should be recognized."
default hardware := 97

# For the 'configuration' trust claim the value 36 stands for
# "Elements of the configuration relevant to security are
#  unavailable to the Verifier."
default configuration := 36

# For the 'filesystem' trust claim, the value 35 stands for
# "File system integrity cannot be verified or is compromised."
default file_system := 35

### The following functions are for parsing UEFI event logs
### These functions are chosen when the related verifier is using 'deps/eventlog'
### crate

# Parse grub algorithm and digest
parse_grub(uefi_event_logs) := grub if {
        some i, j
        uefi_event_logs[i].type_name == "EV_EFI_BOOT_SERVICES_APPLICATION"
        contains(uefi_event_logs[i].details.device_paths[j], "grub")
        grub := {
                "alg": uefi_event_logs[i].digests[0].alg,
                "value": uefi_event_logs[i].digests[0].digest,
        }
}

# Parse shim algorithm and digest
parse_shim(uefi_event_logs) := shim if {
        some i, j
        uefi_event_logs[i].type_name == "EV_EFI_BOOT_SERVICES_APPLICATION"
        contains(uefi_event_logs[i].details.device_paths[j], "shim")
        shim := {
                "alg": uefi_event_logs[i].digests[0].alg,
                "value": uefi_event_logs[i].digests[0].digest,
        }
}

# Parse kernel algorithm and digest
parse_kernel(uefi_event_logs) := kernel if {
        some i
        uefi_event_logs[i].type_name == "EV_IPL"
        contains(uefi_event_logs[i].details.string, "Kernel")
        kernel := {
                "alg": uefi_event_logs[i].digests[0].alg,
                "value": uefi_event_logs[i].digests[0].digest,
        }
}

# Parse initrd algorithm and digest
parse_initrd(uefi_event_logs) := initrd if {
        some i
        uefi_event_logs[i].type_name == "EV_IPL"
        contains(uefi_event_logs[i].details.string, "Initrd")
        initrd := {
                "alg": uefi_event_logs[i].digests[0].alg,
                "value": uefi_event_logs[i].digests[0].digest,
        }
}

# Validate GRUB boot measurements (grub, shim, kernel, initrd)
validate_boot_measurements_grub(uefi_event_logs) if {
        grub := parse_grub(uefi_event_logs)
        shim := parse_shim(uefi_event_logs)
        initrd := parse_initrd(uefi_event_logs)
        kernel := parse_kernel(uefi_event_logs)
        components := [
                {"name": "grub", "value": grub.value, "alg": grub.alg},
                {"name": "shim", "value": shim.value, "alg": shim.alg},
                {"name": "initrd", "value": initrd.value, "alg": initrd.alg},
                {"name": "kernel", "value": kernel.value, "alg": kernel.alg},
        ]
        every component in components {
                measurement_key := sprintf("measurement.%s.%s", [component.name, component.alg])
                component.value in data.reference[measurement_key]
        }
}

# Parse UKI (Unified Kernel Image) algorithm and digest
parse_uki(uefi_event_logs) := uki if {
        some i, j
        uefi_event_logs[i].type_name == "EV_EFI_BOOT_SERVICES_APPLICATION"
        contains(uefi_event_logs[i].details.device_paths[j], "File(\\EFI\\BOOT\\BOOTX64.EFI)")
        uki := {
                "alg": uefi_event_logs[i].digests[0].alg,
                "value": uefi_event_logs[i].digests[0].digest,
        }
}

# Validate UKI boot measurements
validate_boot_measurements_uki(uefi_event_logs) if {
        uki := parse_uki(uefi_event_logs)
        measurement_key := sprintf("measurement.uki.%s", [uki.alg])
        uki.value in data.reference[measurement_key]
}

# Generic function to validate kernel cmdline for any platform and algorithm
validate_kernel_cmdline_uefi(uefi_event_logs) if {
        some prefix in ["grub_cmd linux", "kernel_cmdline", "grub_kernel_cmdline"]
        some i
        uefi_event_logs[i].type_name == "EV_IPL"
        startswith(uefi_event_logs[i].details.string, prefix)
        measurement_key := sprintf("measurement.kernel_cmdline.%s", [uefi_event_logs[i].digests[0].alg])
        uefi_event_logs[i].digests[0].digest in data.reference[measurement_key]
}

# Function to check the file measurements from Measurement_tool integrity
validate_aael_file_measurements(uefi_event_logs) if {
        aael := [e |
                e := uefi_event_logs[_]
                e.type_name == "EV_EVENT_TAG"
                e.details.unicode_name == "AAEL"
                e.details.data.domain == "file"
        ]
        every e in aael {
                key := sprintf("measurement.%s.%s", [e.details.data.domain, e.details.data.operation])
                e.details.data.content in data.reference[key]
        }
}

##### TDX

# Validate executables for GRUB boot mode
executables := 3 if {
        # Check the kernel, initrd, shim and grub measurements for any supported algorithm
        validate_boot_measurements_grub(input.tdx.uefi_event_logs)

}

# Validate executables for UKI boot mode
executables := 3 if {
        # Check the UKI image measurement for any supported algorithm
        validate_boot_measurements_uki(input.tdx.uefi_event_logs)

}

hardware := 2 if {
        # Check the quote is a TDX quote signed by Intel SGX Quoting Enclave
        input.tdx.quote.header.tee_type == "81000000"
        input.tdx.quote.header.vendor_id == "939a7233f79c4ca9940a0db3957f0607"
        # Check TDX Module version and its hash. Also check OVMF code hash.
        # input.tdx.quote.body.mr_seam in data.reference["tdx.mr_seam"]
        # input.tdx.quote.body.tcb_svn in data.reference["tdx.tcb_svn"]
        # input.tdx.quote.body.mr_td in data.reference["tdx.mr_td"]
}

# For GRUB mode: validate boot measurements and kernel cmdline
configuration := 2 if {
        validate_boot_measurements_grub(input.tdx.uefi_event_logs)
        validate_kernel_cmdline_uefi(input.tdx.uefi_event_logs)
}

# For UKI mode: skip kernel cmdline check (embedded in UKI image)
configuration := 2 if {
        validate_boot_measurements_uki(input.tdx.uefi_event_logs)
}

file_system := 2 if {
        input.tdx

        # Root file system hash is included in initrd binary, so we don't need to check it separately
}
POLICIES_EOF
fi

# Generate Attestation Service configuration
cat /etc/trustee/as-config.json | jq '
    .attestation_token_broker.signer.cert_path="/tmp/certs/as-full.pem" |
    .attestation_token_broker.signer.key_path="/tmp/certs/as.key"
' > /tmp/config_with_cert.json
cp /tmp/config_with_cert.json /etc/trustee/as-config.json

# Check if running in container (no systemd)
if [ ! -d "/run/systemd/system" ]; then
    echo "=== Running in container, starting services manually ==="
    
    # Start RVPS service
    echo "Starting RVPS service..."
    /usr/bin/rvps --config /etc/trustee/rvps.json --address 127.0.0.1:50003 &
    RVPS_PID=$!
    sleep 1
    if ! kill -0 $RVPS_PID 2>/dev/null; then
        echo "ERROR: RVPS service failed to start"
        exit 1
    fi
    
    # Start gRPC Attestation Service
    echo "Starting gRPC Attestation Service..."
    /usr/bin/grpc-as --socket 0.0.0.0:50004 --config-file /etc/trustee/as-config.json &
    GRPC_AS_PID=$!
    sleep 1
    if ! kill -0 $GRPC_AS_PID 2>/dev/null; then
        echo "ERROR: gRPC Attestation Service failed to start"
        exit 1
    fi
    
    # Start restful Attestation Service
    echo "Starting restful Attestation Service..."
    /usr/bin/restful-as --socket 0.0.0.0:50005 --config-file /etc/trustee/as-config.json &
    RESTFUL_AS_PID=$!
    sleep 1
    if ! kill -0 $RESTFUL_AS_PID 2>/dev/null; then
        echo "ERROR: restful Attestation Service failed to start"
        exit 1
    fi
    
    # Start KBS service
    echo "Starting KBS service..."
    /usr/bin/kbs --config-file /etc/trustee/kbs-config.toml &
    KBS_PID=$!
    sleep 1
    if ! kill -0 $KBS_PID 2>/dev/null; then
        echo "ERROR: KBS service failed to start"
        exit 1
    fi
    
    # Start Trustee Gateway
    echo "Starting Trustee Gateway..."
    /usr/bin/trustee-gateway --config /etc/trustee/gateway.yml &
    GATEWAY_PID=$!
    sleep 1
    if ! kill -0 $GATEWAY_PID 2>/dev/null; then
        echo "ERROR: Trustee Gateway failed to start"
        exit 1
    fi
    
else
    echo "=== Running on system with systemd, starting Trustee service ==="
    # Enable and start Trustee service (following official documentation)
    systemctl daemon-reload
    systemctl enable trustee
    systemctl restart trustee
fi

# Import image reference value to RVPS
echo "=== Importing image reference value to RVPS ==="

# Create directory for reference values
mkdir -p /opt/trustee/reference-values

# Decode image reference value
echo "${image_reference_value_base64}" | base64 -d > /opt/trustee/reference-values/image-reference-value.json

# Generate register request
provenance=$(base64 --wrap=0 /opt/trustee/reference-values/image-reference-value.json)
cat > /opt/trustee/reference-values/register-request.json << EOF
{
    "version": "0.1.0",
    "type": "sample",
    "payload": "$provenance"
}
EOF

# Wait for RVPS service to be ready
echo "⏳ Waiting for RVPS service to be ready..."
for i in {1..30}; do
    if timeout 5 bash -c 'cat < /dev/null > /dev/tcp/127.0.0.1/50003' 2>/dev/null; then
        echo "✓ RVPS service is ready"
        break
    fi
    echo "   Attempt $i: RVPS not ready yet, waiting 2 seconds..."
    sleep 2
done

# Register image reference value to RVPS
if rvps-tool register --path /opt/trustee/reference-values/register-request.json; then
    echo "✓ Image reference value imported successfully"
else
    echo "ERROR: Failed to import image reference value to RVPS"
    exit 1
fi

echo "=== KBS resources information ==="
echo "Trustee KBS available at kbs:///default/local-resources/"
echo "Secret resources:"
echo "  - kbs:///default/local-resources/disk_passphrase"
echo "  - kbs:///default/local-resources/sshd_server_key"
echo "  - kbs:///default/local-resources/sshd_server_key.pub"
echo "  - kbs:///default/local-resources/openclaw_config"
echo "=== All Trustee services started ==="
